{
  "name": "microfrontend-challange",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/config/*"
  ],
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:host",
    "dev:host": "vite --config apps/host/vite.config.ts --configLoader runner",
    "dev:header": "vite --config apps/header/vite.config.ts --configLoader runner",
    "dev:footer": "vite --config apps/footer/vite.config.ts --configLoader runner",
    "dev:products": "vite --config apps/products/vite.config.ts --configLoader runner",
    "dev:all": "concurrently \"npm run dev:header\" \"npm run dev:footer\" \"npm run dev:products\" \"npm run dev:host\"",
    "build": "tsc -b && npm run build:header && npm run build:footer && npm run build:products && npm run build:host",
    "build:host": "vite build --config apps/host/vite.config.ts --configLoader runner",
    "build:header": "vite build --config apps/header/vite.config.ts --configLoader runner",
    "build:footer": "vite build --config apps/footer/vite.config.ts --configLoader runner",
    "build:products": "vite build --config apps/products/vite.config.ts --configLoader runner",
    "lint": "eslint .",
    "preview": "vite preview --config apps/host/vite.config.ts --configLoader runner",
    "preview:header": "vite preview --config apps/header/vite.config.ts --configLoader runner",
    "preview:footer": "vite preview --config apps/footer/vite.config.ts --configLoader runner",
    "preview:products": "vite preview --config apps/products/vite.config.ts --configLoader runner",
    "preview:all": "concurrently \"npm run preview:header\" \"npm run preview:footer\" \"npm run preview:products\" \"npm run preview\"",
    "prepare": "husky",
    "test": "npm run test --workspaces --if-present",
    "test:header": "vitest run --config apps/header/vitest.config.ts",
    "test:products": "vitest run --config apps/products/vitest.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@module-federation/vite": "^1.16.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
